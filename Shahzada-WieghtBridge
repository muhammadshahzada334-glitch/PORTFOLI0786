<body>

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand text-warning" href="#">SHAHZADA WEIGHBRIDGE</a>
            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#m"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="m">
                <ul class="navbar-nav ms-auto text-center">
                    <li class="nav-item"><a class="nav-link fw-bold" href="#calculator">Calculator</a></li>
                    <li class="nav-item"><a class="nav-link fw-bold" href="#location">Location</a></li>
                    <li class="nav-item mt-2 mt-lg-0"><a class="btn btn-warning fw-bold px-4 ms-lg-3" href="tel:+923356598276"><i class="fas fa-phone-alt me-2"></i>CALL 03356598276</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <header class="hero-section">
        <div class="container">
            <h1 style="font-family: 'Montserrat'; font-weight: 900; font-size: calc(2rem + 1.5vw);">SHAHZADA <span class="text-warning">WEIGHBRIDGE</span></h1>
            <h2 class="fw-bold mb-4 text-white">200 TONS DIGITAL CAPACITY</h2>
            <p class="lead mb-5 opacity-75 text-white">Sparco Road, Moach Goth, Karachi. 24/7 Professional Accuracy.</p>
            <div class="d-grid gap-3 d-sm-flex justify-content-center">
                <a href="#location" class="btn btn-outline-warning btn-lg px-5 rounded-pill">View Map</a>
                <a href="#calculator" class="btn btn-warning btn-lg px-5 fw-bold rounded-pill">Open Calc</a>
            </div>
        </div>
    </header>

    <section id="calculator" class="py-5 bg-dark text-white">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-6">
                    <div class="calc-wrapper">
                        <h3 class="text-center text-warning mb-4 fw-bold">WEIGHT CALCULATOR</h3>
                        <div class="mb-3">
                            <label class="small mb-2 opacity-75">GROSS WEIGHT (KG)</label>
                            <input type="number" id="gross" class="form-control bg-secondary text-white border-0" placeholder="Enter Gross">
                        </div>
                        <div class="mb-4">
                            <label class="small mb-2 opacity-75">TARE WEIGHT (KG)</label>
                            <input type="number" id="tare" class="form-control bg-secondary text-white border-0" placeholder="Enter Tare">
                        </div>
                        <button onclick="calc()" class="btn btn-warning w-100 py-3 fw-bold mb-4">CALCULATE NET WEIGHT</button>
                        
                        <div id="res" class="text-center d-none border-top pt-4">
                            <h1 class="display-3 fw-bold text-warning mb-4"><span id="net">0</span> KG</h1>
                            <button onclick="sendWA()" class="btn-wa"><i class="fab fa-whatsapp me-2"></i>Send Slip to Driver</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="location" class="py-5">
        <div class="container text-center">
            <h2 class="fw-bold mb-4 text-dark">OUR STATION LOCATION</h2>
            <div class="map-container shadow-lg mb-4">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3618.919793318269!2d66.9388147!3d24.8919639!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3eb315000965306d%3A0x6a0f44358a97092c!2sShahzada%20weighbridge!5e0!3m2!1sen!2s!4v1710000000000!5m2!1sen!2s" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
            <a href="https://maps.app.goo.gl/QVliRWGmdojg1ekEu" target="_blank" class="btn btn-dark btn-lg px-5 rounded-pill shadow">
                <i class="fas fa-directions text-warning me-2"></i>OPEN IN GOOGLE MAPS
            </a>
        </div>
    </section>

    <footer class="py-4 text-center bg-white border-top">
        <p class="mb-0 fw-bold text-dark">© 2026 SHAHZADA WEIGHBRIDGE - SPARKCO ROAD KARACHI</p>
    </footer>

    <a href="https://wa.me/923356598276" class="floating-wa shadow-lg"><i class="fab fa-whatsapp"></i></a>

    <script>
        function calc() {
            const g = document.getElementById('gross').value;
            const t = document.getElementById('tare').value;
            if(g && t) {
                document.getElementById('net').innerText = (g - t).toLocaleString();
                document.getElementById('res').classList.remove('d-none');
            }
        }
        function sendWA() {
            const net = document.getElementById('net').innerText;
            const msg = `*SHAHZADA WEIGHBRIDGE SLIP*\nNet Weight: ${net} KG\nLocation: Sparco Road Karachi\n_Computerized Digital Scale_`;
            window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`, '_blank');
        }
    </script>
</body>
</html>
